# Скопируй в .env и заполни
PORT=3000

# Telegram-бот для уведомлений о заказах:
# 1) В Telegram напиши @BotFather → /newbot → получи токен
# 2) Узнай свой chat_id: напиши боту, потом открой
#    https://api.telegram.org/bot<ТОКЕН>/getUpdates → возьми chat.id
TG_TOKEN=
TG_CHAT=

# Ключ для доступа к приватной статистике маржи (/api/admin/stats)
ADMIN_KEY=changeme-secret
